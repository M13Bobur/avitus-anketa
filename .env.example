# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/avitus-anketa

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Telegram Bot (anketa uchun)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Admin Telegram Bot (arizalarni ko'rish uchun)
TELEGRAM_ADMIN_BOT_TOKEN=your-admin-telegram-bot-token
# Telegram API ga ulanish muammosi bo'lsa proxy qo'shing (Clash/V2Ray HTTP port)
# TELEGRAM_PROXY=http://127.0.0.1:7890
# TELEGRAM_RETRY_ATTEMPTS=3
# TELEGRAM_API_ROOT=https://api.telegram.org

# Admin panel build path (relative to project root)
ADMIN_DIST_PATH=apps/admin/dist

# CORS (vergul bilan ajratilgan — dev uchun 3001 ham qo'shing)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Admin dev (faqat npm run dev:admin uchun, ixtiyoriy)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Seed admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=KuchliParol2024!
