# ===========================================
# Docker production (.env)
# Boshqa kompyuterga ko'chirgandan keyin shu faylni .env deb saqlang
# ===========================================

# Server port (host)
APP_PORT=3000

# MUHIM: kuchli parol va token kiriting
JWT_SECRET=change-this-to-a-long-random-secret-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Server IP yoki domen (admin panel ochiladigan manzil)
# Masalan: http://192.168.1.100:3000 yoki https://anketa.sizning-domen.uz
CORS_ORIGIN=http://YOUR_SERVER_IP:3000

# Admin login (birinchi ishga tushganda yaratiladi)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# Telegram proxy (serverda Telegram blok bo'lsa)
# TELEGRAM_PROXY=http://host.docker.internal:7890
# TELEGRAM_RETRY_ATTEMPTS=5

# Qo'shimcha (odatda o'zgartirish shart emas)
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MAX_FILE_SIZE_MB=10
