# ===========================================
# Docker production (.env)
# cp .env.docker.example .env && nano .env
# yoki: bash scripts/setup-env.sh
# ===========================================

APP_PORT=3000

# Majburiy — BotFather dan oling
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Admin bot tokeni (arizalar uchun alohida bot)
TELEGRAM_ADMIN_BOT_TOKEN=your-admin-telegram-bot-token

# setup-env.sh avtomatik yaratadi; qo'lda ham kiriting
JWT_SECRET=change-this-to-a-long-random-secret-key

# setup-env.sh server IP ni avtomatik qo'yadi
CORS_ORIGIN=http://YOUR_SERVER_IP:3000

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=KuchliParol2024!

# Telegram proxy (serverda Telegram blok bo'lsa)
# TELEGRAM_PROXY=http://PROXY_IP:7890
# TELEGRAM_RETRY_ATTEMPTS=5

JWT_EXPIRES_IN=24h
MAX_FILE_SIZE_MB=10
